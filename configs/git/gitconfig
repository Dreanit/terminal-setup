[user]
	name = YOUR_NAME
	email = YOUR_EMAIL

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	dark = true
	side-by-side = true
	line-numbers = true
	syntax-theme = Catppuccin Mocha

[merge]
	conflictStyle = zdiff3

[alias]
	lg = log --graph --oneline --all --decorate
